{
  "name": "apexline-g2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "test:heading": "tsc -p tsconfig.heading-tests.json && node --test tests/heading.test.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "sim": "evenhub-simulator http://localhost:5173",
    "sim:screenshot": "node scripts/capture-glasses.mjs",
    "pack": "npm run build && evenhub pack app.json dist -o apexline.ehpk"
  },
  "dependencies": {
    "@evenrealities/even_hub_sdk": "^0.0.10",
    "leaflet": "^1.9.4",
    "vite": "^5.4.19"
  },
  "devDependencies": {
    "@evenrealities/evenhub-cli": "^0.1.13",
    "@types/leaflet": "^1.9.21",
    "typescript": "^5.8.3"
  }
}
